# 1. Check for active msiexec processes
$InstallerProcesses = Get-Process -Name msiexec -ErrorAction SilentlyContinue

# 2. Check for the System Installer Mutex (Global\_MSIExecute)
$InstallerActive = $false
try {
    $Mutex = [System.Threading.Mutex]::OpenExisting("Global\_MSIExecute")
    $Mutex.Dispose()
    $InstallerActive = $true
} catch {
    $InstallerActive = $false
}

# 3. If any install activity is found, kill everything
if ($InstallerProcesses -or $InstallerActive) {
    Write-Host "Concurrent installation detected. Terminating all installer processes..." -ForegroundColor Yellow
    
    # Force stop all msiexec processes
    Stop-Process -Name msiexec -Force -ErrorAction SilentlyContinue
    
    # Restart the Windows Installer service to clear any hung states
    Restart-Service -Name msiserver -Force
    
    Write-Host "All concurrent installs have been stopped. System ready." -ForegroundColor Green
} else {
    Write-Host "No active installations found. Proceeding..." -ForegroundColor Green
}
